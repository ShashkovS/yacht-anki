# This file is the only student-facing config for Docker, Dokploy, and Docker e2e tests.
# Edit this file when you want to change Docker ports, Docker URLs, Docker secrets, or Docker test settings.
# Copy one line here when you add another Docker setting that students may need to change.
DOCKER_PROJECT_NAME=templatepwa_local
DOCKER_APP_MODE=dev
DOCKER_COOKIE_SECRET=local-docker-secret
DOCKER_DB_PATH=/data/app.sqlite3
DOCKER_FRONTEND_PORT=8088
DOCKER_BACKEND_PORT=8089
DOCKER_FRONTEND_ORIGIN=http://localhost:8088
# In same-origin production behind a reverse proxy, set this to the same public site origin.
DOCKER_VITE_BACKEND_URL=http://localhost:8089
DOCKER_E2E_PROJECT_NAME=templatepwa_e2e
DOCKER_E2E_APP_MODE=dev
DOCKER_E2E_COOKIE_SECRET=playwright-docker-secret
DOCKER_E2E_FRONTEND_PORT=4188
DOCKER_E2E_BACKEND_PORT=4189
DOCKER_E2E_FRONTEND_ORIGIN=http://localhost:4188
DOCKER_E2E_VITE_BACKEND_URL=http://localhost:4189
DOCKER_E2E_FRONTEND_URL=http://localhost:4188
